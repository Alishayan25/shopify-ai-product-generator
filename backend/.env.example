# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Shopify
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=write_products,read_products,write_product_listings,read_product_listings,write_inventory,read_inventory
SHOPIFY_APP_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
OPENAI_VISION_MODEL=gpt-4-vision-preview
OPENAI_IMAGE_MODEL=dall-e-3

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Database
DATABASE_URL=postgresql://dev:password@localhost:5432/shopify_app
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=dev
DATABASE_PASSWORD=password
DATABASE_NAME=shopify_app

# Redis
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRY=24h
