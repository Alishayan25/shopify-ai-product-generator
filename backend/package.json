{
  "name": "shopify-ai-backend",
  "version": "1.0.0",
  "description": "Backend API for Shopify AI Product Generator",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "db:migrate": "node src/db/migrate.js",
    "db:rollback": "node src/db/rollback.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "keywords": ["shopify", "ai", "product-generation"],
  "author": "Alishayan25",
  "license": "MIT",
  "dependencies": {
    "@shopify/shopify-app-express": "^2.14.0",
    "@shopify/shopify-api": "^11.3.0",
    "axios": "^1.6.2",
    "bull": "^4.11.4",
    "cloudinary": "^1.40.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^4.20.1",
    "pg": "^8.11.2",
    "redis": "^4.6.11",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^9.1.2",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/jest": "^29.5.8",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
